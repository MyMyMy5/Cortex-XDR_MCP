# Cortex MCP Server - Environment Variables
# Copy this file to .env and fill in your values

# Cortex XDR/XSIAM API URL (from Settings > Configurations > API Keys > "Copy API URL")
CORTEX_MCP_PAPI_URL=https://api-<your-tenant>.xdr.<region>.paloaltonetworks.com

# API Key (from Settings > Configurations > API Keys)
CORTEX_MCP_PAPI_AUTH_HEADER=<your-api-key>

# API Key ID
CORTEX_MCP_PAPI_AUTH_ID=<your-api-key-id>
